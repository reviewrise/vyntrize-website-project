# GitHub Container Registry
GITHUB_REPOSITORY=reviewrise/vyntrize-website-project

# PostgreSQL Database Configuration
POSTGRES_USER=vyntrize_user
POSTGRES_PASSWORD=change-this-secure-password
POSTGRES_DB=vyntrize_db

# Database URLs (use the postgres service name as host)
# Replace <user>, <password>, and <db> with the values above
VYNTRIZE_DATABASE_URL=postgresql://vyntrize_user:change-this-secure-password@vyntrize-postgres:5432/vyntrize_db
CRM_DATABASE_URL=postgresql://vyntrize_user:change-this-secure-password@vyntrize-postgres:5432/vyntrize_db

# Session Secret (generate with: openssl rand -base64 32)
SESSION_SECRET=your-secret-key-here-change-this-in-production

# Node Environment
NODE_ENV=production

# Optional: Database SSL Configuration
# VYNTRIZE_DATABASE_SSL_MODE=require
# VYNTRIZE_DATABASE_SSL_CA=
# VYNTRIZE_DATABASE_SSL_CERT=
# VYNTRIZE_DATABASE_SSL_KEY=
