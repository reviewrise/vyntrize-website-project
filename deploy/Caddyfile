# Redirect bare domain to www (canonical)
http://vyntrise.com {
    redir https://www.vyntrise.com{uri} 301
}

http://www.vyntrise.com {
    # Block the phantom /en locale prefix — redirect to canonical paths.
    # NOTE: destination must NOT include /en or it will loop.
    @enExact path /en
    redir @enExact https://www.vyntrise.com/ 301

    @enLocale path_regexp ^/en/(.*)$
    redir @enLocale https://www.vyntrise.com/{re.enLocale.1} 301

    reverse_proxy vyntrize-website:3013
}

http://crm.vyntrise.com {
    reverse_proxy vyntrize-crm:3014
}
