# Shared Vyntrize database (used by both vyntrize-website and vyntrize-crm)
DATABASE_URL="postgresql://vyntrize_user:vyntrize_password@localhost:5432/vyntrize_db?sslmode=disable"

# Node environment
NODE_ENV="development"
PORT=3013

# Postgres superuser — used by db:setup script only (not at runtime)
POSTGRES_SUPERUSER_URL="postgresql://postgres:password@localhost:5432/postgres"
