# Shared Vyntrize database (used by both vyntrize-website and vyntrize-crm)
CRM_DATABASE_URL="postgresql://vyntrize_user:vyntrize_password@localhost:5432/vyntrize_db?sslmode=disable"

# Postgres superuser URL — used by setup script only (not at runtime)
POSTGRES_SUPERUSER_URL="postgresql://postgres:password@localhost:5432/postgres"

# Session secret for iron-session (must be at least 32 characters)
SESSION_SECRET="your-super-secret-session-key-min-32-chars-here"

# Node environment
NODE_ENV="development"
PORT=3014

# Seed credentials
SEED_ADMIN_EMAIL="admin@vyntrise.com"
SEED_ADMIN_PASSWORD="ChangeMe123!"
SEED_ADMIN_NAME="Admin User"
SEED_DEFAULT_PASSWORD="Vyntrise2026!"

# ─── Email Configuration (SMTP) ───────────────────────────────────────────────

# SMTP Server Settings (Example for Resend)
SMTP_HOST="smtp.resend.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="resend"
SMTP_PASSWORD="re_YourResendApiKeyHere"

# Email Settings
EMAIL_FROM_ADDRESS="sales@yourdomain.com"
EMAIL_FROM_NAME="Vyntrize CRM"
EMAIL_REPLY_TO="sales@yourdomain.com"

# Email Tracking
EMAIL_TRACKING_DOMAIN="http://localhost:3014"
EMAIL_TRACKING_ENABLED="true"

# Email Queue Settings
EMAIL_QUEUE_BATCH_SIZE="50"
EMAIL_QUEUE_RATE_LIMIT="100"
EMAIL_QUEUE_MAX_RETRIES="3"

# ─── AI Pipeline Agent System ─────────────────────────────────────────────────

# Redis Configuration (Required for persistent agent queue in production)
# Set this to enable BullMQ-backed agent processing (events survive restarts & auto-retry)
# Without this, agents run in-memory (fine for local dev)
REDIS_URL="redis://localhost:6379"

# AI Provider Keys
# Choose provider: openai, gemini, or auto (auto-selects first available)
AI_PROVIDER="gemini"
OPENAI_API_KEY="sk-your-openai-api-key-here"
OPENAI_MODEL="gpt-4o"
GEMINI_API_KEY="your-gemini-api-key-here"
GEMINI_MODEL="gemini-3-flash-preview"

# Agent Feature Flags (Optional - defaults to true)
AGENT_LEAD_SCORING_ENABLED="true"
AGENT_TASK_AUTOMATION_ENABLED="true"
AGENT_STAGNATION_DETECTION_ENABLED="true"
AGENT_EMAIL_GENERATION_ENABLED="true"
AGENT_NEXT_BEST_ACTION_ENABLED="true"
AGENT_STAGE_PROGRESSION_ENABLED="true"
AGENT_DRIP_CAMPAIGN_ENABLED="true"
AGENT_WORKFLOW_RULE_ENABLED="true"

# Agent Job Queue Configuration (Optional)
AGENT_JOB_CONCURRENCY="5"

# ─── Google OAuth Configuration ───────────────────────────────────────────────
GOOGLE_CLIENT_ID="your-google-client-id-here"
GOOGLE_CLIENT_SECRET="your-google-client-secret-here"
GOOGLE_REDIRECT_URI="http://localhost:3014/api/auth/google/callback"

# ─── Webhook ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
VYNTRISE_WEBHOOK_SECRET="your-webhook-secret-here"

# ─── Public URLs ──────────────────────────────────────────────────────────────
# Baked into the Next.js bundle at build time. Use localhost for local dev,
# and your real domain (e.g. https://crm.vyntrise.com) in production.
NEXT_PUBLIC_CRM_URL="http://localhost:3014"
