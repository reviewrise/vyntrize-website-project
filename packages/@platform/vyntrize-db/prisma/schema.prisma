 // @platform/vyntrize-db — Prisma schema for the shared vyntrize_db database
// Used by: apps/vyntrize-website (contact_submissions)
//          apps/vyntrize-crm (crm_* tables)

generator client {
  provider   = "prisma-client-js"
  output     = "../src/generated/client"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

// ─── Website: Contact Form Submissions ───────────────────────────────────────

model ContactSubmission {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  firstName  String
  lastName   String
  email      String
  company    String?
  intent     String
  message    String  @db.Text

  status     ContactStatus @default(NEW)
  priority   Priority      @default(MEDIUM)
  assignedTo String?
  notes      String?       @db.Text
  source     String?
  ipAddress  String?
  userAgent  String?

  @@index([email])
  @@index([status])
  @@index([createdAt])
  @@map("contact_submissions")
}

enum ContactStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL_SENT
  WON
  LOST
  SPAM
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// ─── CRM: Users ──────────────────────────────────────────────────────────────

model CrmUser {
  id           String    @id @default(cuid())
  email        String    @unique
  displayName  String
  passwordHash String
  role         CrmRole   @default(MEMBER)
  isActive     Boolean   @default(true)
  bookingSlug  String?   @unique
  timezone     String?   @default("America/New_York")
  // Profile fields used in email footers
  jobTitle     String?
  phone        String?
  avatarUrl    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  assignedLeads       Lead[]            @relation("AssignedLeads")
  activities          Activity[]
  auditLogs           AuditLog[]
  leadNotes           LeadNote[]        @relation("LeadNoteAuthor")

  assignedTasks       LeadTask[]        @relation("AssignedTasks")
  createdTasks        LeadTask[]        @relation("CreatedTasks")
  emailTemplates      EmailTemplate[]   @relation("EmailTemplateAuthor")
  sentEmails          EmailTracking[]   @relation("SentEmails")
  pipelineAutoAssigns PipelineStage[]   @relation("PipelineAutoAssign")
  emailCampaigns      EmailCampaign[]   @relation("EmailCampaignAuthor")
  emailLogs           EmailLog[]        @relation("EmailLogUser")
  approvedAgentActions AgentAction[]    @relation("AgentActionApprover")

  connectedAccounts   ConnectedAccount[]
  calendarEvents      CalendarEvent[]
  availabilityRules   AvailabilityRule[]
  bookingSettings     BookingSettings?

  notifications            Notification[]           @relation("UserNotifications")
  notificationPreferences  NotificationPreference[] @relation("UserNotificationPreferences")

  @@map("crm_users")
}

enum CrmRole {
  ADMIN
  MEMBER
}

// ─── CRM: Companies ──────────────────────────────────────────────────────────

model Company {
  id        String    @id @default(cuid())
  name      String
  website   String?
  industry  String?
  notes     String?   @db.Text
  
  // Enrichment fields
  employeeCount  Int?
  annualRevenue  BigInt?
  enrichmentData Json?
  
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  contacts  Contact[]
  leads     Lead[]

  @@map("crm_companies")
}

// ─── CRM: Contacts ───────────────────────────────────────────────────────────

model Contact {
  id          String    @id @default(cuid())
  firstName   String
  lastName    String
  email       String    @unique
  phone       String?
  jobTitle    String?
  companyId   String?
  company     Company?  @relation(fields: [companyId], references: [id])
  
  // Social & engagement fields
  linkedinUrl      String?
  twitterHandle    String?
  lastContactedAt  DateTime?

  // Stripe Integration
  stripeCustomerId String? @unique
  
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  leads          Lead[]
  activities     Activity[]
  emailLogs      EmailLog[]
  calendarEvents CalendarEvent[]

  @@index([email])
  @@index([deletedAt])
  @@map("crm_contacts")
}

// ─── CRM: Leads ──────────────────────────────────────────────────────────────

model Lead {
  id          String      @id @default(cuid())
  title       String
  stage       LeadStage   @default(NEW)
  contactId   String
  contact     Contact     @relation(fields: [contactId], references: [id])
  companyId   String?
  company     Company?    @relation(fields: [companyId], references: [id])
  dealValue   Decimal?    @db.Decimal(12, 2)
  closeDate   DateTime?
  assigneeId  String?
  assignee    CrmUser?    @relation("AssignedLeads", fields: [assigneeId], references: [id])
  closingNote String?     @db.Text
  
  // Analytics & Scoring fields
  score              Int?       @default(0)
  qualificationStatus String?   @default("new")
  lastActivityAt     DateTime?
  visitorId          String?
  sessionId          String?
  
  // Attribution fields
  source      String?
  medium      String?
  campaign    String?
  utmContent  String?
  utmTerm     String?

  // Pipeline Automation
  manualOverride Boolean @default(false)

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  activities      Activity[]
  leadActivities  LeadActivity[]
  leadScores      LeadScore[]
  leadSource      LeadSource?    @relation("LeadSourceAttribution")
  leadNotes       LeadNote[]
  leadTasks       LeadTask[]
  deals           Deal[]
  emailTracking   EmailTracking[]
  emailLogs       EmailLog[]     @relation("EmailLogLead")
  agentActions    AgentAction[]
  dripEnrollments DripEnrollment[]
  calendarEvents  CalendarEvent[]

  @@index([stage])
  @@index([score])
  @@index([qualificationStatus])
  @@index([lastActivityAt])
  @@index([visitorId])
  @@map("crm_leads")
}

enum LeadStage {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL_SENT
  WON
  LOST
}

// ─── CRM: Activities ─────────────────────────────────────────────────────────

model Activity {
  id           String         @id @default(cuid())
  type         ActivityType
  body         String         @db.Text
  originalBody String?        @db.Text
  isEdited     Boolean        @default(false)
  duration     Int?
  direction    CallDirection?
  leadId       String?
  lead         Lead?          @relation(fields: [leadId], references: [id])
  contactId    String?
  contact      Contact?       @relation(fields: [contactId], references: [id])
  userId       String
  user         CrmUser        @relation(fields: [userId], references: [id])
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([leadId])
  @@index([contactId])
  @@index([createdAt])
  @@map("crm_activities")
}

enum ActivityType {
  NOTE
  CALL
  EMAIL
}

enum CallDirection {
  INBOUND
  OUTBOUND
}

// ─── CRM: Audit Log ──────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  entityType String
  entityId   String
  field      String?
  prevValue  String?
  newValue   String?
  userId     String
  user       CrmUser  @relation(fields: [userId], references: [id])
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@map("crm_audit_logs")
}

// ─── CRM: Import Tracking ────────────────────────────────────────────────────

model ImportRecord {
  id                  String   @id @default(cuid())
  contactSubmissionId String   @unique
  contactId           String?
  leadId              String?
  skipped             Boolean  @default(false)
  importedAt          DateTime @default(now())

  @@map("crm_import_records")
}

// ─── Website: Page Views ──────────────────────────────────────────────────────

model PageView {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  path      String          // e.g. "/", "/contact", "/work"
  referrer  String?         // full referrer URL
  source    String?         // parsed referrer domain
  userAgent String?
  sessionId String          // random ID stored in cookie — deduplicates unique visitors
  device    String?         // "mobile" | "tablet" | "desktop"
  country   String?         // future: from IP geo

  @@index([path])
  @@index([sessionId])
  @@index([createdAt])
  @@map("page_views")
}

// ─── Analytics: Events ────────────────────────────────────────────────────────

model AnalyticsEvent {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  sessionId  String
  visitorId  String?
  userId     String?

  eventType  String   // 'page_view', 'click', 'form_submit', 'custom'
  eventName  String?
  eventData  Json?

  // Page context
  pageUrl    String   @db.Text
  pageTitle  String?
  referrer   String?  @db.Text

  // UTM parameters
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  utmContent  String?
  utmTerm     String?

  // Device & browser
  userAgent   String?  @db.Text
  deviceType  String?  // 'desktop', 'mobile', 'tablet'
  browser     String?
  os          String?

  // Location (anonymized)
  ipAddressHash String?
  country       String?
  city          String?

  @@index([sessionId])
  @@index([visitorId])
  @@index([eventType])
  @@index([createdAt])
  @@map("analytics_events")
}

// ─── Analytics: Sessions ──────────────────────────────────────────────────────

model AnalyticsSession {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessionId  String   @unique
  visitorId  String
  userId     String?

  // Session timing
  startedAt        DateTime
  endedAt          DateTime?
  durationSeconds  Int?

  // Session metrics
  pageViews   Int @default(0)
  eventsCount Int @default(0)

  // Entry point
  landingPage   String?  @db.Text
  entryReferrer String?  @db.Text

  // UTM parameters (from entry)
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  utmContent  String?
  utmTerm     String?

  // Device info
  deviceType String?
  browser    String?
  os         String?

  // Location
  country String?
  city    String?

  // Conversion tracking
  converted       Boolean @default(false)
  conversionType  String?

  @@index([visitorId])
  @@index([startedAt])
  @@index([utmCampaign])
  @@map("analytics_sessions")
}

// ─── Analytics: Daily Metrics ─────────────────────────────────────────────────

model AnalyticsDailyMetric {
  id         Int      @id @default(autoincrement())
  metricDate DateTime @unique @db.Date

  // Traffic metrics
  totalSessions    Int @default(0)
  totalPageViews   Int @default(0)
  uniqueVisitors   Int @default(0)

  // Engagement metrics
  avgSessionDurationSeconds Int?
  avgPagesPerSession        Decimal? @db.Decimal(10, 2)
  bounceRate                Decimal? @db.Decimal(5, 2)

  // Conversion metrics
  totalConversions Int     @default(0)
  conversionRate   Decimal? @db.Decimal(5, 2)

  // Top sources (JSONB for flexibility)
  topSources   Json?
  topPages     Json?
  topCampaigns Json?

  createdAt DateTime @default(now())

  @@map("analytics_daily_metrics")
}

// ─── Lead Intelligence: Activities ────────────────────────────────────────────

model LeadActivity {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())

  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  activityType String  // 'page_view', 'email_open', 'form_submit', 'download', etc.
  activityName String?
  activityData Json?

  // Context
  pageUrl   String?  @db.Text
  sessionId String?

  // Metadata
  ipAddressHash String?
  userAgent     String?  @db.Text

  @@index([leadId])
  @@index([activityType])
  @@index([createdAt])
  @@map("lead_activities")
}

// ─── Lead Intelligence: Scores ────────────────────────────────────────────────

model LeadScore {
  id            Int      @id @default(autoincrement())
  calculatedAt  DateTime @default(now())

  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  score         Int  @default(0)
  previousScore Int?

  // Scoring factors (what contributed to the score)
  factors Json?

  // Qualification
  qualificationStatus String?

  @@index([leadId])
  @@index([score])
  @@index([calculatedAt])
  @@map("lead_scores")
}

// ─── Lead Intelligence: Source Attribution ────────────────────────────────────

model LeadSource {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  leadId String @unique
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade, name: "LeadSourceAttribution")

  // First touch attribution
  firstTouchSource   String?
  firstTouchMedium   String?
  firstTouchCampaign String?
  firstTouchContent  String?
  firstTouchTerm     String?
  firstTouchAt       DateTime?

  // Last touch attribution
  lastTouchSource   String?
  lastTouchMedium   String?
  lastTouchCampaign String?
  lastTouchContent  String?
  lastTouchTerm     String?
  lastTouchAt       DateTime?

  // Multi-touch (all touchpoints)
  touchpoints Json?

  @@map("lead_sources")
}

// ─── CRM Enhancement: Notes ───────────────────────────────────────────────────

model LeadNote {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  userId String?
  user   CrmUser? @relation(fields: [userId], references: [id], name: "LeadNoteAuthor")

  note     String  @db.Text
  isPinned Boolean @default(false)

  @@index([leadId])
  @@index([createdAt])
  @@map("lead_notes")
}

// ─── CRM Enhancement: Tasks ───────────────────────────────────────────────────

enum TaskActionType {
  MANUAL
  EMAIL
  SMS
  STATUS_UPDATE
  WEBHOOK
}

model LeadTask {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  assignedToId String?
  assignedTo   CrmUser? @relation(fields: [assignedToId], references: [id], name: "AssignedTasks")

  createdById String?
  createdBy   CrmUser? @relation(fields: [createdById], references: [id], name: "CreatedTasks")

  title       String
  description String?  @db.Text

  status      TaskStatus   @default(PENDING)
  priority    TaskPriority @default(MEDIUM)

  dueDate     DateTime?
  completedAt DateTime?

  // Hybrid Automation Fields
  taskType    TaskActionType @default(MANUAL)
  payload     Json?
  executionLog Json?

  @@index([leadId])
  @@index([assignedToId])
  @@index([status])
  @@index([dueDate])
  @@map("lead_tasks")
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
  FAILED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// ─── CRM Enhancement: Email Templates ─────────────────────────────────────────

model EmailTemplate {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String?
  user   CrmUser? @relation(fields: [userId], references: [id], name: "EmailTemplateAuthor")

  name      String
  subject   String
  body      String   @db.Text
  
  // Template type for categorization and automation
  type      EmailTemplateType @default(GENERAL)

  // Template variables (e.g., {{firstName}}, {{companyName}})
  variables Json?

  isShared Boolean @default(false)
  
  emailTracking EmailTracking[]
  emailCampaigns EmailCampaign[]
  emailLogs     EmailLog[]      @relation("EmailLogTemplate")

  @@index([userId])
  @@index([type])
  @@map("email_templates")
}

enum EmailTemplateType {
  WELCOME              // Welcome/onboarding emails
  INITIAL_OUTREACH     // First contact emails
  FOLLOW_UP            // Follow-up after meeting/call
  PROPOSAL             // Proposal/quote emails
  RE_ENGAGEMENT        // Re-engagement for inactive leads
  STAGE_CHANGE         // Automated stage change emails
  ENGAGEMENT_RESPONSE  // Response to email opens/clicks
  NEWSLETTER           // Newsletter/update emails
  GENERAL              // General purpose templates
}

// ─── CRM Enhancement: Email Tracking ──────────────────────────────────────────

model EmailTracking {
  id     Int      @id @default(autoincrement())
  sentAt DateTime @default(now())

  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  sentById String
  sentBy   CrmUser @relation(fields: [sentById], references: [id], name: "SentEmails")

  templateId Int?
  template   EmailTemplate? @relation(fields: [templateId], references: [id])

  subject String
  body    String @db.Text

  openedAt  DateTime?
  clickedAt DateTime?
  repliedAt DateTime?

  openCount  Int @default(0)
  clickCount Int @default(0)

  @@index([leadId])
  @@index([sentById])
  @@index([sentAt])
  @@map("email_tracking")
}

// ─── Email System: Campaigns ──────────────────────────────────────────────────

model EmailCampaign {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  name        String
  subject     String
  templateId  Int?
  template    EmailTemplate? @relation(fields: [templateId], references: [id])
  
  status      EmailCampaignStatus @default(DRAFT)
  scheduledAt DateTime?
  sentAt      DateTime?
  
  // Targeting
  targetType   String   // 'all', 'filtered', 'manual'
  targetFilter Json?    // Filter criteria for contacts
  
  // Stats
  totalRecipients Int @default(0)
  sentCount       Int @default(0)
  deliveredCount  Int @default(0)
  openedCount     Int @default(0)
  clickedCount    Int @default(0)
  bouncedCount    Int @default(0)
  failedCount     Int @default(0)
  
  // Relations
  userId      String
  user        CrmUser  @relation(fields: [userId], references: [id], name: "EmailCampaignAuthor")
  emails      EmailLog[]
  
  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("email_campaigns")
}

enum EmailCampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  FAILED
  CANCELLED
}

// ─── Email System: Email Logs ─────────────────────────────────────────────────

model EmailLog {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Email details
  subject     String
  body        String   @db.Text
  htmlBody    String?  @db.Text
  fromEmail   String
  fromName    String?
  toEmail     String
  toName      String?
  replyTo     String?
  
  // Tracking
  trackingId  String   @unique
  status      EmailStatus @default(QUEUED)
  sentAt      DateTime?
  deliveredAt DateTime?
  openedAt    DateTime?
  clickedAt   DateTime?
  bouncedAt   DateTime?
  failedAt    DateTime?
  errorMessage String?  @db.Text
  
  // Counts
  openCount   Int @default(0)
  clickCount  Int @default(0)
  
  // Relations
  contactId   String?
  contact     Contact? @relation(fields: [contactId], references: [id])
  leadId      String?
  lead        Lead?    @relation(fields: [leadId], references: [id], name: "EmailLogLead")
  campaignId  String?
  campaign    EmailCampaign? @relation(fields: [campaignId], references: [id])
  templateId  Int?
  template    EmailTemplate? @relation(fields: [templateId], references: [id], name: "EmailLogTemplate")
  userId      String?
  user        CrmUser?  @relation(fields: [userId], references: [id], name: "EmailLogUser")
  
  // Events
  events      EmailEvent[]
  
  @@index([contactId])
  @@index([leadId])
  @@index([campaignId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("email_logs")
}

enum EmailStatus {
  QUEUED
  SENDING
  SENT
  DELIVERED
  OPENED
  CLICKED
  BOUNCED
  FAILED
}

// ─── Email System: Email Events ───────────────────────────────────────────────

model EmailEvent {
  id          Int      @id @default(autoincrement())
  createdAt   DateTime @default(now())
  
  emailLogId  String
  emailLog    EmailLog @relation(fields: [emailLogId], references: [id], onDelete: Cascade)
  
  eventType   EmailEventType
  eventData   Json?    // Additional event data (IP, user agent, link clicked, etc.)
  
  @@index([emailLogId])
  @@index([eventType])
  @@index([createdAt])
  @@map("email_events")
}

enum EmailEventType {
  SENT
  DELIVERED
  OPENED
  CLICKED
  BOUNCED
  FAILED
  UNSUBSCRIBED
}

// ─── Email System: Email Queue ────────────────────────────────────────────────

model EmailQueue {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  emailData   Json     // Serialized email data
  status      EmailQueueStatus @default(PENDING)
  attempts    Int      @default(0)
  maxAttempts Int      @default(3)
  scheduledFor DateTime?
  processedAt DateTime?
  errorMessage String?  @db.Text
  
  @@index([status])
  @@index([scheduledFor])
  @@index([createdAt])
  @@map("email_queue")
}

enum EmailQueueStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// ─── Email System: Unsubscribes ───────────────────────────────────────────────

model EmailUnsubscribe {
  id          Int      @id @default(autoincrement())
  createdAt   DateTime @default(now())
  
  email       String   @unique
  reason      String?
  contactId   String?
  
  @@index([email])
  @@map("email_unsubscribes")
}

// ─── CRM Enhancement: Pipeline Stages ─────────────────────────────────────────

model PipelineStage {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name        String
  description String?  @db.Text

  stageOrder  Int      @unique
  probability Int      @default(0) // Win probability (0-100)

  // Automation rules
  autoAssignToId   String?
  autoAssignTo     CrmUser? @relation(fields: [autoAssignToId], references: [id], name: "PipelineAutoAssign")
  autoCreateTask   Boolean  @default(false)
  taskTemplate     Json?

  isActive Boolean @default(true)

  @@map("pipeline_stages")
}

// ─── CRM Enhancement: Custom Fields ───────────────────────────────────────────

model CustomField {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())

  entityType String // 'lead', 'contact', 'company'

  fieldName  String
  fieldLabel String
  fieldType  String // 'text', 'number', 'date', 'select', 'multi_select', 'boolean'

  options      Json?
  defaultValue String?

  isRequired   Boolean @default(false)
  isSearchable Boolean @default(true)

  displayOrder Int?

  values CustomFieldValue[]

  @@unique([entityType, fieldName])
  @@map("custom_fields")
}

// ─── CRM Enhancement: Custom Field Values ─────────────────────────────────────

model CustomFieldValue {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customFieldId Int
  customField   CustomField @relation(fields: [customFieldId], references: [id], onDelete: Cascade)

  entityType String
  entityId   String

  value String? @db.Text

  @@index([entityType, entityId])
  @@index([customFieldId])
  @@map("custom_field_values")
}

// ─── Pipeline Automation: Stage Progression Rules ─────────────────────────────

model StageProgressionRule {
  id            String        @id @default(cuid())
  fromStage     LeadStage
  toStage       LeadStage
  criteria      Json
  autonomyLevel AutonomyLevel
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([fromStage, isActive])
  @@map("stage_progression_rules")
}

// ─── Pipeline Automation: Drip Sequences ──────────────────────────────────────

model DripSequence {
  id             String        @id @default(cuid())
  name           String
  description    String?
  triggerType    String
  triggerConfig  Json
  stopConditions Json
  autonomyLevel  AutonomyLevel
  isActive       Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  steps       DripStep[]
  enrollments DripEnrollment[]

  @@map("drip_sequences")
}

// ─── Pipeline Automation: Drip Steps ─────────────────────────────────────────

model DripStep {
  id              String       @id @default(cuid())
  sequenceId      String
  sequence        DripSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  stepOrder       Int
  delayHours      Int
  subjectTemplate String
  bodyTemplate    String       @db.Text
  branchCondition String
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([sequenceId, stepOrder])
  @@map("drip_steps")
}

// ─── Pipeline Automation: Drip Enrollments ───────────────────────────────────

model DripEnrollment {
  id               String               @id @default(cuid())
  leadId           String
  lead             Lead                 @relation(fields: [leadId], references: [id], onDelete: Cascade)
  sequenceId       String
  sequence         DripSequence         @relation(fields: [sequenceId], references: [id])
  currentStepIndex Int                  @default(0)
  status           DripEnrollmentStatus @default(ACTIVE)
  enrolledAt       DateTime             @default(now())
  lastStepSentAt   DateTime?
  stoppedReason    String?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  @@index([leadId])
  @@index([status])
  @@index([sequenceId])
  @@map("drip_enrollments")
}

// ─── Pipeline Automation: Workflow Rules ──────────────────────────────────────

model WorkflowRule {
  id            String        @id @default(cuid())
  name          String
  description   String?
  triggerEvent  String
  conditions    Json
  actions       Json
  autonomyLevel AutonomyLevel
  isActive      Boolean       @default(true)
  priority      Int           @default(100)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([triggerEvent, isActive])
  @@map("workflow_rules")
}

// ─── AI Agent System ──────────────────────────────────────────────────────────

model AgentAction {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  agentType     AgentType
  actionType    ActionType
  leadId        String
  lead          Lead       @relation(fields: [leadId], references: [id], onDelete: Cascade)

  reasoning     String     @db.Text
  status        ActionStatus @default(PENDING)
  autonomyLevel AutonomyLevel

  // Approval workflow
  approvedBy    String?
  approvedByUser CrmUser?  @relation(fields: [approvedBy], references: [id], name: "AgentActionApprover")
  approvedAt    DateTime?
  rejectedReason String?   @db.Text

  // Execution
  executedAt    DateTime?
  executionError String?   @db.Text

  // Metadata (JSON for flexibility)
  metadata      Json?

  // AI Feedback loop — stores user-corrected email text for few-shot personalisation
  correctedText String?   @db.Text

  @@index([leadId])
  @@index([agentType])
  @@index([status])
  @@index([createdAt])
  @@map("agent_actions")
}

model AgentRule {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  agentType     AgentType
  ruleName      String
  ruleConfig    Json      // Configuration specific to the rule
  autonomyLevel AutonomyLevel
  isActive      Boolean   @default(true)
  priority      Int       @default(5)

  @@unique([agentType, ruleName])
  @@index([agentType])
  @@index([isActive])
  @@map("agent_rules")
}

model AgentMetric {
  id           Int      @id @default(autoincrement())
  calculatedAt DateTime @default(now())

  agentType    AgentType
  metricName   String
  metricValue  Float
  metadata     Json?

  @@index([agentType])
  @@index([metricName])
  @@index([calculatedAt])
  @@map("agent_metrics")
}

// ─── Agent System Enums ───────────────────────────────────────────────────────

enum AgentType {
  LEAD_SCORING
  TASK_AUTOMATION
  STAGNATION_DETECTION
  EMAIL_GENERATION
  NEXT_BEST_ACTION
  PREDICTIVE_ANALYTICS
  STAGE_PROGRESSION
  DRIP_CAMPAIGN
  REVENUE_FORECASTING
  OPENAI_PROVIDER
  WORKFLOW_RULE
}

enum ActionType {
  SCORE_UPDATE
  TASK_CREATE
  EMAIL_SEND
  STAGE_CHANGE
  ALERT
  PREDICTION_UPDATE
  DRIP_ENROLL
  RULE_EXECUTION
}

enum ActionStatus {
  PENDING
  APPROVED
  REJECTED
  EXECUTED
  FAILED
}

enum AutonomyLevel {
  FULLY_AUTONOMOUS
  SUGGEST_APPROVE
  COPILOT
}

enum DripEnrollmentStatus {
  ACTIVE
  COMPLETED
  STOPPED
}

// ─── Calendar Integration ─────────────────────────────────────────────────────

model ConnectedAccount {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  userId       String
  user         CrmUser  @relation(fields: [userId], references: [id], onDelete: Cascade)

  provider     String   // 'google', 'microsoft'
  providerId   String   // The account ID from the provider
  email        String
  accessToken  String   @db.Text
  refreshToken String?  @db.Text
  expiresAt    DateTime?
  scope        String?  @db.Text

  @@unique([provider, providerId])
  @@index([userId])
  @@map("connected_accounts")
}

model CalendarEvent {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  title        String
  description  String?  @db.Text
  location     String?

  startTime    DateTime
  endTime      DateTime
  isAllDay     Boolean  @default(false)
  
  // Status of the event: SCHEDULED, ATTENDED, MISSED, CANCELLED
  status       String   @default("SCHEDULED")

  // Ownership
  userId       String
  user         CrmUser  @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Relations to CRM entities
  leadId       String?
  lead         Lead?    @relation(fields: [leadId], references: [id])
  contactId    String?
  contact      Contact? @relation(fields: [contactId], references: [id])

  // Sync state
  externalId      String?   // ID from Google/Outlook Calendar
  syncedAt        DateTime?

  // Booking: Google Meet
  meetLink        String?   // e.g. https://meet.google.com/abc-xyz-def

  // Booking: cancel & reschedule tokens (sent in confirmation email)
  cancelToken     String?   @unique
  rescheduleToken String?   @unique
  cancelledAt     DateTime?

  @@index([userId])
  @@index([startTime])
  @@index([leadId])
  @@index([contactId])
  @@index([cancelToken])
  @@index([rescheduleToken])
  @@map("calendar_events")
}

// ─── Booking: Availability Rules ─────────────────────────────────────────────

model AvailabilityRule {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId    String
  user      CrmUser  @relation(fields: [userId], references: [id], onDelete: Cascade)

  dayOfWeek Int      // 0=Sun, 1=Mon, 2=Tue, 3=Wed, 4=Thu, 5=Fri, 6=Sat
  startHour Int      // e.g. 9
  startMin  Int      @default(0)
  endHour   Int      // e.g. 17
  endMin    Int      @default(0)
  isActive  Boolean  @default(true)

  @@index([userId])
  @@unique([userId, dayOfWeek])
  @@map("availability_rules")
}

// ─── Booking: Per-Expert Settings ────────────────────────────────────────────

model BookingSettings {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  userId          String   @unique
  user            CrmUser  @relation(fields: [userId], references: [id], onDelete: Cascade)

  title           String   @default("Book a Consultation")
  description     String?  @db.Text
  durationMinutes Int      @default(30)  // 15, 30, 45, or 60
  bufferMinutes   Int      @default(15)  // gap between back-to-back meetings
  generateMeet    Boolean  @default(true) // auto-create Google Meet room

  @@map("booking_settings")
}

// ─── System Settings ──────────────────────────────────────────────────────────

model SystemSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt

  @@map("system_settings")
}

// ─── Deals ────────────────────────────────────────────────────────────────────

model Deal {
  id          String     @id @default(cuid())
  title       String
  leadId      String
  lead        Lead       @relation(fields: [leadId], references: [id])
  contactId   String?
  companyId   String?
  value       Decimal    @db.Decimal(12, 2)
  currency    String     @default("USD")
  status      DealStatus @default(OPEN)
  closedAt    DateTime?
  notes       String?    @db.Text
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  invoices    Invoice[]

  @@index([leadId])
  @@index([status])
  @@index([createdAt])
  @@map("crm_deals")
}

enum DealStatus {
  OPEN
  WON
  LOST
  ON_HOLD
}

// ─── Invoices ─────────────────────────────────────────────────────────────────

model Invoice {
  id          String        @id @default(cuid())
  number      String        @unique  // e.g. INV-2026-001
  dealId      String
  deal        Deal          @relation(fields: [dealId], references: [id], onDelete: Cascade)
  status      InvoiceStatus @default(DRAFT)
  issueDate   DateTime      @default(now())
  dueDate     DateTime
  subtotal    Decimal       @db.Decimal(12, 2)
  taxRate     Decimal?      @db.Decimal(5, 2)   // percentage e.g. 16.00
  taxAmount   Decimal?      @db.Decimal(12, 2)
  discount    Decimal?      @db.Decimal(12, 2)  // absolute amount deducted
  total       Decimal       @db.Decimal(12, 2)
  amountPaid  Decimal       @default(0) @db.Decimal(12, 2)
  currency    String        @default("USD")
  notes       String?       @db.Text
  sentAt      DateTime?
  paidAt      DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // Stripe Integration
  stripeInvoiceId  String?  @unique   // Stripe invoice ID (in_xxx)
  stripePaymentUrl String?            // Hosted payment page URL
  stripeStatus     String?            // Raw Stripe status for debugging

  lineItems   InvoiceLineItem[]
  payments    InvoicePayment[]

  @@index([dealId])
  @@index([status])
  @@index([dueDate])
  @@index([createdAt])
  @@map("crm_invoices")
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
}

// ─── Invoice Line Items ───────────────────────────────────────────────────────

model InvoiceLineItem {
  id          Int     @id @default(autoincrement())
  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  quantity    Decimal @db.Decimal(10, 2)
  unitPrice   Decimal @db.Decimal(12, 2)
  total       Decimal @db.Decimal(12, 2)

  @@index([invoiceId])
  @@map("crm_invoice_line_items")
}

// ─── Invoice Payments ─────────────────────────────────────────────────────────

model InvoicePayment {
  id        String   @id @default(cuid())
  invoiceId String
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  amount    Decimal  @db.Decimal(12, 2)
  method    String   // 'bank_transfer' | 'cash' | 'cheque' | 'mobile_money' | 'other'
  reference String?
  paidAt    DateTime @default(now())
  notes     String?
  createdAt DateTime @default(now())

  @@index([invoiceId])
  @@index([paidAt])
  @@map("crm_invoice_payments")
}

// ─── Notification Center: Enums ───────────────────────────────────────────────

enum NotificationChannel {
  IN_APP
  EMAIL
  SMS
}

enum NotificationEventType {
  LEAD_CREATED
  STAGE_CHANGED
  TASK_CREATED
  TASK_COMPLETED
  CALENDAR_EVENT_CREATED
  CALENDAR_EVENT_UPDATED
  AGENT_ACTION_PENDING
  MEETING_ATTENDED
  MEETING_MISSED
}

// ─── Notification Center: Models ──────────────────────────────────────────────

model Notification {
  id          String                @id @default(cuid())
  userId      String
  user        CrmUser               @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  eventType   NotificationEventType
  title       String                @db.VarChar(255)
  body        String?               @db.VarChar(2000)
  entityType  String?
  entityId    String?
  channel     NotificationChannel   @default(IN_APP)
  isRead      Boolean               @default(false)
  isDismissed Boolean               @default(false)
  readAt      DateTime?
  createdAt   DateTime              @default(now())

  @@index([userId, isDismissed, isRead, createdAt(sort: Desc)])
  @@map("crm_notifications")
}

model NotificationPreference {
  id        String                @id @default(cuid())
  userId    String
  user      CrmUser               @relation("UserNotificationPreferences", fields: [userId], references: [id], onDelete: Cascade)
  eventType NotificationEventType
  channel   NotificationChannel
  isEnabled Boolean               @default(true)
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  @@unique([userId, eventType, channel])
  @@map("crm_notification_preferences")
}
