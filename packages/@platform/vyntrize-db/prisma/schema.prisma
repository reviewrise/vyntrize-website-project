// @platform/vyntrize-db — Prisma schema for the shared vyntrize_db database
// Used by: apps/vyntrize-website (contact_submissions)
//          apps/vyntrize-crm (crm_* tables)

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
}

// ─── Website: Contact Form Submissions ───────────────────────────────────────

model ContactSubmission {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  firstName  String
  lastName   String
  email      String
  company    String?
  intent     String
  message    String  @db.Text

  status     ContactStatus @default(NEW)
  priority   Priority      @default(MEDIUM)
  assignedTo String?
  notes      String?       @db.Text
  source     String?
  ipAddress  String?
  userAgent  String?

  @@index([email])
  @@index([status])
  @@index([createdAt])
  @@map("contact_submissions")
}

enum ContactStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL_SENT
  WON
  LOST
  SPAM
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// ─── CRM: Users ──────────────────────────────────────────────────────────────

model CrmUser {
  id           String    @id @default(cuid())
  email        String    @unique
  displayName  String
  passwordHash String
  role         CrmRole   @default(MEMBER)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  assignedLeads Lead[]     @relation("AssignedLeads")
  activities    Activity[]
  auditLogs     AuditLog[]

  @@map("crm_users")
}

enum CrmRole {
  ADMIN
  MEMBER
}

// ─── CRM: Companies ──────────────────────────────────────────────────────────

model Company {
  id        String    @id @default(cuid())
  name      String
  website   String?
  industry  String?
  notes     String?   @db.Text
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  contacts  Contact[]
  leads     Lead[]

  @@map("crm_companies")
}

// ─── CRM: Contacts ───────────────────────────────────────────────────────────

model Contact {
  id          String    @id @default(cuid())
  firstName   String
  lastName    String
  email       String    @unique
  phone       String?
  jobTitle    String?
  companyId   String?
  company     Company?  @relation(fields: [companyId], references: [id])
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  leads       Lead[]
  activities  Activity[]

  @@index([email])
  @@index([deletedAt])
  @@map("crm_contacts")
}

// ─── CRM: Leads ──────────────────────────────────────────────────────────────

model Lead {
  id          String      @id @default(cuid())
  title       String
  stage       LeadStage   @default(NEW)
  contactId   String
  contact     Contact     @relation(fields: [contactId], references: [id])
  companyId   String?
  company     Company?    @relation(fields: [companyId], references: [id])
  dealValue   Decimal?    @db.Decimal(12, 2)
  closeDate   DateTime?
  assigneeId  String?
  assignee    CrmUser?    @relation("AssignedLeads", fields: [assigneeId], references: [id])
  closingNote String?     @db.Text
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  activities  Activity[]

  @@index([stage])
  @@map("crm_leads")
}

enum LeadStage {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL_SENT
  WON
  LOST
}

// ─── CRM: Activities ─────────────────────────────────────────────────────────

model Activity {
  id           String         @id @default(cuid())
  type         ActivityType
  body         String         @db.Text
  originalBody String?        @db.Text
  isEdited     Boolean        @default(false)
  duration     Int?
  direction    CallDirection?
  leadId       String?
  lead         Lead?          @relation(fields: [leadId], references: [id])
  contactId    String?
  contact      Contact?       @relation(fields: [contactId], references: [id])
  userId       String
  user         CrmUser        @relation(fields: [userId], references: [id])
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([leadId])
  @@index([contactId])
  @@index([createdAt])
  @@map("crm_activities")
}

enum ActivityType {
  NOTE
  CALL
  EMAIL
}

enum CallDirection {
  INBOUND
  OUTBOUND
}

// ─── CRM: Audit Log ──────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  entityType String
  entityId   String
  field      String?
  prevValue  String?
  newValue   String?
  userId     String
  user       CrmUser  @relation(fields: [userId], references: [id])
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@map("crm_audit_logs")
}

// ─── CRM: Import Tracking ────────────────────────────────────────────────────

model ImportRecord {
  id                  String   @id @default(cuid())
  contactSubmissionId String   @unique
  contactId           String?
  leadId              String?
  skipped             Boolean  @default(false)
  importedAt          DateTime @default(now())

  @@map("crm_import_records")
}

// ─── Website: Page Views ──────────────────────────────────────────────────────

model PageView {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  path      String          // e.g. "/", "/contact", "/work"
  referrer  String?         // full referrer URL
  source    String?         // parsed referrer domain
  userAgent String?
  sessionId String          // random ID stored in cookie — deduplicates unique visitors
  device    String?         // "mobile" | "tablet" | "desktop"
  country   String?         // future: from IP geo

  @@index([path])
  @@index([sessionId])
  @@index([createdAt])
  @@map("page_views")
}
